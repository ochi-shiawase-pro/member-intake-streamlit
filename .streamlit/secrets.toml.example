# Streamlit Cloud の Secrets に入れる見本です。
# 実際の値はここへ保存せず、Streamlit Cloud 側へ設定してください。

spreadsheet_name = "億万長者リスト"
worksheet_name = "受付一覧"

# Ghost(Pro) の Integrations → Add custom integration で確認した値を入れます。
# 設定すると「新規登録」「登録内容の変更」は送信と同時に Ghost へ反映します。
# （ご利用停止は保留/手動運用のまま）
ghost_admin_api_url = "https://YOUR-SITE.ghost.io"
ghost_admin_api_key = "YOUR_KEY_ID:YOUR_SECRET_HEX"
# 迷ったらこのままでOKです。環境により調整したい場合だけ変更します。
ghost_admin_api_version = "v5.0"

[gcp_service_account]
type = "service_account"
project_id = "YOUR_PROJECT_ID"
private_key_id = "YOUR_PRIVATE_KEY_ID"
private_key = "-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
client_email = "YOUR_SERVICE_ACCOUNT_EMAIL"
client_id = "YOUR_CLIENT_ID"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "YOUR_CLIENT_X509_CERT_URL"
universe_domain = "googleapis.com"
